        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [{\n        \"text\": \"Analyze this AI response and check if all 8 intake fields have been collected: full name, business type, service type, features, budget, timeline, email, phone.\\n\\nAI response: {{$node['Prepare Reply'].json['aiReply']}}\\n\\nUser message history context: {{$node['Prepare Reply'].json['userMessage']}}\\n\\nRespond ONLY in this exact JSON format with no extra text:\\n{ \\\"complete\\\": true, \\\"name\\\": \\\"\\\", \\\"business\\\": \\\"\\\", \\\"serviceType\\\": \\\"\\\", \\\"features\\\": \\\"\\\", \\\"budget\\\": \\\"\\\", \\\"timeline\\\": \\\"\\\", \\\"email\\\": \\\"\\\", \\\"phone\\\": \\\"\\\" }\\n\\nOnly set complete to true if ALL 8 fields are confirmed collected. Otherwise set complete to false.\"\n      }]\n    }\n  ]\n}",
